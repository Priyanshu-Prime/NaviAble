# NaviAble — Environment template. Copy to .env and adjust.
#   cp .env.example .env

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=naviable
POSTGRES_PASSWORD=naviable_dev
POSTGRES_DB=naviable
DATABASE_URL=postgresql+psycopg://naviable:naviable_dev@localhost:5432/naviable

# ── Google Places (server-side) ───────────────────────────────────────────
# Restrict this key to "Places API" + "Geocoding API" only.
# It is NEVER embedded in the mobile app — only the Maps SDK key is.
GOOGLE_PLACES_API_KEY=

# ── ML model paths ──────────────────────────────────────────────────────────
YOLO_WEIGHTS_PATH=YoloModel11/runs/stair_ramp_m4_v1/weights/best.pt
ROBERTA_CHECKPOINT_DIR=NaviAble_RoBERTa_Final

# ── Late fusion (must sum to 1.0) ───────────────────────────────────────────
VISION_WEIGHT=0.60
NLP_WEIGHT=0.40
VISION_THRESHOLD=0.205

# ── Uploads ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=backend/uploads
MAX_IMAGE_BYTES=10485760
PUBLIC_BASE_URL=http://localhost:8000
STATIC_PREFIX=/static/

# ── App ─────────────────────────────────────────────────────────────────────
NAVIABLE_DEMO_MODE=false
NAVIABLE_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ── Training & admin ────────────────────────────────────────────────────────
# Admin token for /api/v1/training/export endpoint. Keep secret in prod.
ADMIN_TOKEN=changeme-dev-only

# ── Aggregate scoring ────────────────────────────────────────────────────────
# Recency-weighted trust decay: 180-day half-life means contributions
# older than 6 months contribute less weight.
TRUST_RECENCY_HALF_LIFE_DAYS=180

# Default search radius (metres) and maximum allowed via API.
NEARBY_DEFAULT_RADIUS_M=800
NEARBY_MAX_RADIUS_M=10000

# ── Optional third-party keys (kept from earlier scaffolding) ───────────────
GROQ_API_KEY=
ROBOFLOW_API_KEY=
